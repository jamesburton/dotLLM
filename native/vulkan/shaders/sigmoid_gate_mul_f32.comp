#version 450
// In-place sigmoid-gated multiply: attnOut[i] *= sigmoid(gate[i]).
//
// Used by the Qwen3MoeHybrid FULL-attention (non-GDN) layer — step 8 of
// ForwardAttnBody, i.e. the "multiply attention output element-wise by
// sigmoid(Gate)" stage (see Qwen3MoeHybridTransformerModel.cs, the
// `<item>Multiply attention output element-wise by sigmoid(Gate).</item>`
// step of the attn forward pass).
//
// Pointwise, no reduction. One thread per element. Both buffers are flat
// over the full attention output tensor — typically [seq_len, n_q_head *
// head_dim] but the shader doesn't care about the 2-D split because the
// op is independent per element.
//
// Mirrors the CPU expression
//
//   attnOut[i] = attnOut[i] * (1.0f / (1.0f + MathF.Exp(-gate[i])))
//
// Single fp32 reciprocal and one exp — same operation order as the
// existing moe_sigmoid_gated_add_f32.comp helper, just without the per-token
// add (gate here is per-element, not per-token).
//
// Dispatch:
//   local_size_x = 256
//   groupCount.x = ceil(n_total / 256)

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430)          buffer BufOut  { float attnOut[]; };   // RW
layout(set = 0, binding = 1, std430) readonly buffer BufGate { float gate[];    };   // R

layout(push_constant) uniform PushConstants {
    int n_total;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (int(i) >= pc.n_total) return;

    float g   = gate[i];
    float sig = 1.0 / (1.0 + exp(-g));
    attnOut[i] = attnOut[i] * sig;
}
