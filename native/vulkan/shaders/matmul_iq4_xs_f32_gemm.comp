#version 450
// IQ4_XS batched matrix multiplication (prefill-path GEMM).
//
//   C[N, M] = B[N, K] @ W_iq4xs[M, K]^T      with W_iq4xs dequantized on the fly.
//
// Companion to matmul_iq4_xs_f32_gemv.comp. The byte layout is identical:
// each weight row holds (K / 256) IQ4_XS super-blocks of 136 bytes:
//   bytes [0,1]    = fp16 d
//   bytes [2,3]    = scales_h (uint16 LE)
//   bytes [4..7]   = scales_l[4]
//   bytes [8..135] = qs[128]    (8 sub-blocks of 16 bytes each)
//
// Tiling:
//   Output tile  = 16 rows of C (TILE_N) x 16 cols of C (TILE_M) = 256 cells.
//   Workgroup    = (16, 16, 1) = 256 threads, one thread per output cell.
//   K-chunk      = 32 elements (one IQ4_XS *sub-block*).
//
// Each super-block carries 8 sub-blocks of 32 elements. The K loop iterates
// 8 * blocksPerRow chunks.

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufB { float b[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufC { float c[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;             // multiple of 256
    uint N;
    uint blocksPerRow;  // = K / 256 (super-blocks)
    uint rowUints;
} pc;

const uint TILE_M = 16u;
const uint TILE_N = 16u;
const uint CHUNK  = 32u;
const uint IQ4_XS_BLOCK_BYTES = 136u;
const uint IQ4_XS_GROUP_SIZE  = 256u;
const uint NUM_SUBBLOCKS      = 8u;

const float KVALUES_IQ4NL[16] = float[16](
    -127.0, -104.0, -83.0, -65.0, -49.0, -35.0, -22.0, -10.0,
       1.0,   13.0,  25.0,  38.0,  53.0,  69.0,  89.0, 113.0
);

shared float sharedB[TILE_N * CHUNK];
shared float sharedW[TILE_M * CHUNK];

uint readByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

void main() {
    uint m = gl_WorkGroupID.x * TILE_M + gl_LocalInvocationID.x;
    uint t = gl_WorkGroupID.y * TILE_N + gl_LocalInvocationID.y;
    uint tid = gl_LocalInvocationID.y * TILE_M + gl_LocalInvocationID.x;

    uint mBase = gl_WorkGroupID.x * TILE_M;
    uint tBase = gl_WorkGroupID.y * TILE_N;

    uint rowByteStride = pc.blocksPerRow * IQ4_XS_BLOCK_BYTES;

    float acc = 0.0;

    uint totalChunks = pc.blocksPerRow * NUM_SUBBLOCKS;
    for (uint chunk = 0u; chunk < totalChunks; chunk++) {
        uint kBlock = chunk / NUM_SUBBLOCKS;            // super-block index
        uint ib     = chunk - kBlock * NUM_SUBBLOCKS;   // sub-block in super-block (0..7)
        uint kBase  = kBlock * IQ4_XS_GROUP_SIZE + ib * CHUNK;

        // ── 1. Stage sharedB[TILE_N, 32]. ──
        {
            uint flat0 = tid * 2u;
            uint flat1 = flat0 + 1u;

            uint row0 = flat0 >> 5u;
            uint col0 = flat0 - (row0 << 5u);
            uint row1 = flat1 >> 5u;
            uint col1 = flat1 - (row1 << 5u);

            uint tGlobal0 = tBase + row0;
            uint tGlobal1 = tBase + row1;

            float v0 = 0.0;
            float v1 = 0.0;
            if (tGlobal0 < pc.N) v0 = b[tGlobal0 * pc.K + kBase + col0];
            if (tGlobal1 < pc.N) v1 = b[tGlobal1 * pc.K + kBase + col1];
            sharedB[flat0] = v0;
            sharedB[flat1] = v1;
        }

        // ── 2. Dequantize sharedW[TILE_M, 32]. ──
        {
            uint mLocal  = tid >> 4u;
            uint lane    = tid - (mLocal << 4u);
            uint mGlobal = mBase + mLocal;

            float dl = 0.0;
            uint subQsBase = 0u;
            bool rowValid = mGlobal < pc.M;
            if (rowValid) {
                uint blockByteBase = mGlobal * rowByteStride + kBlock * IQ4_XS_BLOCK_BYTES;
                float d = readHalf(blockByteBase);
                uint scalesH = readByte(blockByteBase + 2u)
                             | (readByte(blockByteBase + 3u) << 8u);
                uint scalesLByte = readByte(blockByteBase + 4u + (ib >> 1u));
                uint low  = (scalesLByte >> (4u * (ib & 1u))) & 0xFu;
                uint high = (scalesH >> (2u * ib)) & 0x3u;
                int  ls   = int(low | (high << 4u)) - 32;
                dl        = d * float(ls);
                subQsBase = blockByteBase + 8u + ib * 16u;
            }

            uint colLo = lane;
            uint colHi = lane + 16u;
            float wLo = 0.0;
            float wHi = 0.0;
            if (rowValid) {
                uint byteVal = readByte(subQsBase + lane);
                uint nLo = byteVal & 0xFu;
                uint nHi = byteVal >> 4u;
                wLo = dl * KVALUES_IQ4NL[nLo];
                wHi = dl * KVALUES_IQ4NL[nHi];
            }

            uint sBase = mLocal * CHUNK;
            sharedW[sBase + colLo] = wLo;
            sharedW[sBase + colHi] = wHi;
        }

        barrier();

        {
            uint bOff = gl_LocalInvocationID.y * CHUNK;
            uint wOff = gl_LocalInvocationID.x * CHUNK;
            float chunkSum = 0.0;
            for (uint j = 0u; j < CHUNK; j++) {
                chunkSum += sharedB[bOff + j] * sharedW[wOff + j];
            }
            acc += chunkSum;
        }

        barrier();
    }

    if (m < pc.M && t < pc.N) {
        c[t * pc.M + m] = acc;
    }
}
