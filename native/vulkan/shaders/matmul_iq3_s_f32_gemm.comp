#version 450
// IQ3_S batched matrix multiplication (prefill-path GEMM).
//
//   C[N, M] = B[N, K] @ W_iq3s[M, K]^T   with W_iq3s dequantized on the fly.
//
// Tile: 16x16 cells per workgroup. K-chunk = 32 elements = one IQ3_S
// sub-block (4 pair-of-8 groups; each pair: 4 elems from g1, 4 from g2).
// 8 chunks per super-block.

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW       { uint  weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufB       { float b[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufC       { float c[]; };
layout(set = 0, binding = 3, std430) readonly  buffer BufGrid    { uint  iq3sGrid[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint N;
    uint blocksPerRow;
    uint rowUints;
} pc;

const uint TILE_M = 16u;
const uint TILE_N = 16u;
const uint CHUNK  = 32u;
const uint IQ3_S_BLOCK_BYTES = 110u;
const uint IQ3_S_GROUP_SIZE  = 256u;
const uint NUM_SUBBLOCKS     = 8u;

shared float sharedB[TILE_N * CHUNK];
shared float sharedW[TILE_M * CHUNK];

uint readByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

uint gridByte(uint absIdx) {
    uint u = iq3sGrid[absIdx >> 2u];
    return (u >> ((absIdx & 3u) * 8u)) & 0xFFu;
}

// Decode one element at (mGlobal, sub-block ib32, column col in [0..32)).
float decodeElem(uint mGlobal, uint kBlock, uint ib32, uint col) {
    if (mGlobal >= pc.M) return 0.0;
    uint blockByteBase = mGlobal * pc.blocksPerRow * IQ3_S_BLOCK_BYTES
                       + kBlock * IQ3_S_BLOCK_BYTES;
    float d = readHalf(blockByteBase);
    uint qsBase     = blockByteBase + 2u;
    uint qhBase     = blockByteBase + 2u + IQ3_S_GROUP_SIZE / 4u;
    uint signsBase  = blockByteBase + 2u + IQ3_S_GROUP_SIZE / 4u + IQ3_S_GROUP_SIZE / 32u;
    uint scalesBase = blockByteBase + 2u + IQ3_S_GROUP_SIZE / 4u + IQ3_S_GROUP_SIZE / 32u + IQ3_S_GROUP_SIZE / 8u;

    uint scaleByte = readByte(scalesBase + (ib32 >> 1u));
    uint subScale  = ((ib32 & 1u) == 0u) ? (scaleByte & 0xFu) : (scaleByte >> 4u);
    float db = d * float(1u + 2u * subScale);

    uint qhByte = readByte(qhBase + ib32);
    uint l  = col >> 3u;       // 0..3
    uint jj = col & 7u;        // 0..7
    bool useG2 = (jj >= 4u);
    uint j4 = useG2 ? (jj - 4u) : jj;
    uint hiBit = useG2
        ? ((qhByte << (7u - 2u * l)) & 0x100u)
        : ((qhByte << (8u - 2u * l)) & 0x100u);
    uint lo = readByte(qsBase + ib32 * 8u + 2u * l + (useG2 ? 1u : 0u));
    uint gridIdx = lo | hiBit;
    uint signs   = readByte(signsBase + ib32 * 4u + l);
    float g    = float(gridByte(gridIdx * 4u + j4));
    float sign = ((signs & (1u << jj)) != 0u) ? -1.0 : 1.0;
    return db * g * sign;
}

void main() {
    uint m = gl_WorkGroupID.x * TILE_M + gl_LocalInvocationID.x;
    uint t = gl_WorkGroupID.y * TILE_N + gl_LocalInvocationID.y;
    uint tid = gl_LocalInvocationID.y * TILE_M + gl_LocalInvocationID.x;

    uint mBase = gl_WorkGroupID.x * TILE_M;
    uint tBase = gl_WorkGroupID.y * TILE_N;

    float acc = 0.0;

    uint totalChunks = pc.blocksPerRow * NUM_SUBBLOCKS;
    for (uint chunk = 0u; chunk < totalChunks; chunk++) {
        uint kBlock = chunk / NUM_SUBBLOCKS;
        uint ib32   = chunk - kBlock * NUM_SUBBLOCKS;
        uint kBase  = kBlock * IQ3_S_GROUP_SIZE + ib32 * CHUNK;

        // Stage sharedB.
        {
            uint flat0 = tid * 2u;
            uint flat1 = flat0 + 1u;
            uint row0 = flat0 >> 5u;
            uint col0 = flat0 - (row0 << 5u);
            uint row1 = flat1 >> 5u;
            uint col1 = flat1 - (row1 << 5u);
            uint tGlobal0 = tBase + row0;
            uint tGlobal1 = tBase + row1;
            float v0 = 0.0;
            float v1 = 0.0;
            if (tGlobal0 < pc.N) v0 = b[tGlobal0 * pc.K + kBase + col0];
            if (tGlobal1 < pc.N) v1 = b[tGlobal1 * pc.K + kBase + col1];
            sharedB[flat0] = v0;
            sharedB[flat1] = v1;
        }

        // Dequantize sharedW.
        {
            uint mLocal  = tid >> 4u;
            uint lane    = tid - (mLocal << 4u);
            uint mGlobal = mBase + mLocal;

            float wLo = decodeElem(mGlobal, kBlock, ib32, lane);
            float wHi = decodeElem(mGlobal, kBlock, ib32, lane + 16u);

            uint sBase = mLocal * CHUNK;
            sharedW[sBase + lane]         = wLo;
            sharedW[sBase + lane + 16u]   = wHi;
        }

        barrier();

        {
            uint bOff = gl_LocalInvocationID.y * CHUNK;
            uint wOff = gl_LocalInvocationID.x * CHUNK;
            float chunkSum = 0.0;
            for (uint j = 0u; j < CHUNK; j++) {
                chunkSum += sharedB[bOff + j] * sharedW[wOff + j];
            }
            acc += chunkSum;
        }

        barrier();
    }

    if (m < pc.M && t < pc.N) {
        c[t * pc.M + m] = acc;
    }
}
