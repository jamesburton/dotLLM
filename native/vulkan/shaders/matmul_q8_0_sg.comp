#version 450
#extension GL_KHR_shader_subgroup_basic      : require
#extension GL_KHR_shader_subgroup_arithmetic : require

// Q8_0 GEMV — subgroup-arithmetic reduce. Same algorithm as matmul_q8_0.comp;
// only the workgroup-scope reduction is replaced by:
//   1. subgroupAdd  across each subgroup (no barrier)
//   2. subgroup-0 lane writes its partial to a tiny shared slot
//   3. ONE barrier
//   4. subgroup 0 does a second subgroupAdd across the partials
//   5. broadcast result via shared slot
//
// Barrier count drops from log2(128)+1 = 8 to 2, matching the rmsnorm_f32_sg
// pattern. WG=128 keeps row-fan-out the same as the reference shader.

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufX { float x[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufY { float y[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint blocksPerRow;
    uint rowUints;
} pc;

int readQsByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    int b = int((u >> shift) & 0xFFu);
    return (b ^ 0x80) - 0x80;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

// Sized to cover every realistic config: WG=128 / subgroupSize=4 -> 32 partials.
shared float partials[32];
shared float resultBroadcast;

void main() {
    uint m = gl_WorkGroupID.x;
    if (m >= pc.M) return;

    uint tid = gl_LocalInvocationID.x;
    uint threads = gl_WorkGroupSize.x;
    uint rowByteStride = pc.blocksPerRow * 34u;
    uint rowByteBase = m * rowByteStride;

    float acc = 0.0;
    for (uint b = tid; b < pc.blocksPerRow; b += threads) {
        uint blockByteBase = rowByteBase + b * 34u;
        float d = readHalf(blockByteBase);
        uint xBase = b * 32u;
        float blockSum = 0.0;
        for (uint j = 0u; j < 32u; j++) {
            int qv = readQsByte(blockByteBase + 2u + j);
            blockSum += float(qv) * x[xBase + j];
        }
        acc += d * blockSum;
    }

    float subgroupSum = subgroupAdd(acc);
    if (subgroupElect()) {
        partials[gl_SubgroupID] = subgroupSum;
    }
    barrier();

    if (gl_SubgroupID == 0u) {
        float v = (gl_SubgroupInvocationID < gl_NumSubgroups)
                ? partials[gl_SubgroupInvocationID]
                : 0.0;
        float total = subgroupAdd(v);
        if (subgroupElect()) {
            resultBroadcast = total;
        }
    }
    barrier();

    if (tid == 0u) y[m] = resultBroadcast;
}
