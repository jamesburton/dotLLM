uint readByte(uint absByteOff) {
    uint u = src[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = src[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = src[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

uint readU16(uint absByteOff) {
    return readByte(absByteOff) | (readByte(absByteOff + 1u) << 8u);
}

// Sign-extend an 8-bit byte (0..255) to a signed int.
int sext8(uint b) {
    return int(b) - int((b & 0x80u) << 1u);
}

void main() {
    uint sb = gl_WorkGroupID.x;
    if (sb >= pc.totalSuperblocks) return;

    uint t = gl_LocalInvocationID.x;       // 0..255
    uint blockBase = sb * IQ1_S_BLOCK_BYTES;

    float d = readHalf(blockBase);

    uint ib   = t >> 5u;        // 0..7  sub-block
    uint elem = t & 31u;        // 0..31 element within sub-block
    uint l    = elem >> 3u;     // 0..3  group within sub-block
    uint j    = elem & 7u;      // 0..7  element within group

    uint qhBase = blockBase + 2u + 32u;  // qh[] starts at byte 34
    uint qhVal  = readU16(qhBase + ib * 2u);

    float dl    = d * float(2 * int((qhVal >> 12u) & 7u) + 1);
    float delta = ((qhVal & 0x8000u) != 0u) ? -IQ1S_DELTA : IQ1S_DELTA;

    uint qsByte = readByte(blockBase + 2u + ib * 4u + l);
    uint idx    = qsByte | (((qhVal >> (3u * l)) & 7u) << 8u);

    // Read grid[j]: byte at offset j within the 8-byte ggml uint64.
    uint gridLo = iq1s_grid_lo_hi[2u * idx];
    uint gridHi = iq1s_grid_lo_hi[2u * idx + 1u];
    uint gridWord = (j < 4u) ? gridLo : gridHi;
    uint shift    = (j & 3u) * 8u;
    int  g        = sext8((gridWord >> shift) & 0xFFu);

    dst[sb * IQ1_S_GROUP_SIZE + t] = dl * (float(g) + delta);
}
