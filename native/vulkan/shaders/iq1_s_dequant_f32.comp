// IQ1_S dequantization to FP32.
//
// Reads a tightly-packed IQ1_S blob (one 50-byte super-block per 256 elements)
// and produces a contiguous FP32 buffer. Layout matches llama.cpp's
// block_iq1_s and DotLLM.Cpu.Kernels.Dequantize.DequantizeIQ1_S:
//   bytes [0,1]    = fp16 d
//   bytes [2..33]  = qs[32]   — low 8 bits of grid index per group of 8 elements
//   bytes [34..49] = qh[8]    — uint16 LE, per 32-element sub-block:
//                                 bits  0..2  = grid-index high 3 bits for group 0
//                                 bits  3..5  = grid-index high 3 bits for group 1
//                                 bits  6..8  = grid-index high 3 bits for group 2
//                                 bits  9..11 = grid-index high 3 bits for group 3
//                                 bits 12..14 = 3-bit per-block scale (dl-factor)
//                                 bit  15     = sign of delta (0 -> +0.125, 1 -> -0.125)
//
// 8 sub-blocks of 32 elements each. Per sub-block ib in [0,8):
//   dl    = d * (2 * ((qh[ib] >> 12) & 7) + 1)
//   delta = (qh[ib] & 0x8000) ? -0.125 : +0.125
// Per group l in [0,4) of 8 elements:
//   idx       = qs[ib*4 + l] | (((qh[ib] >> 3*l) & 7) << 8)   // 11-bit, 2048 entries
//   grid[j]   = signed int8 from a 2048-entry codebook (each entry packs 8 ternary ints)
//   y[j]      = dl * (grid[j] + delta)
//
// Dispatch:
//   One workgroup per IQ1_S super-block. local_size_x = 256 — one thread per element.

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  src[]; };
layout(set = 0, binding = 1, std430) writeonly buffer BufY { float dst[]; };

layout(push_constant) uniform PushConstants {
    uint totalSuperblocks;
    uint srcUints;
} pc;

const uint IQ1_S_BLOCK_BYTES = 50u;
const uint IQ1_S_GROUP_SIZE  = 256u;
const float IQ1S_DELTA = 0.125;

