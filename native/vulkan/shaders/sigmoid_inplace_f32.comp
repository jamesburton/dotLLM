#version 450
// In-place sigmoid activation: x[i] = 1 / (1 + exp(-x[i])).
//
// Mirrors System.Numerics.Tensors.TensorPrimitives.Sigmoid (the CPU reference
// used by VulkanQwen3MoeHybridTransformerModel.ComputeDecayAndBetaOnHost when
// it computes beta = sigmoid(beta_proj)). Used by the GDN token-mixing path
// to fold the write-gate sigmoid onto the device alongside the gdn_decay_f32
// pass — eliminating the D2H/H2D roundtrip.
//
// Pointwise, no reduction — one thread per element.
// Dispatch:
//   local_size_x = 256
//   groupCount.x = ceil(n / 256)
//
// Numerical parity: GLSL exp() is within ≤4 ULP of MathF.Exp across the
// supported range; the chain `1 / (1 + exp(-x))` matches TensorPrimitives'
// scalar fallback to within ≤4 ULP for any well-conditioned input.

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) buffer BufX { float x[]; };

layout(push_constant) uniform PushConstants {
    uint n;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.n) return;

    float v = x[i];
    x[i] = 1.0 / (1.0 + exp(-v));
}
