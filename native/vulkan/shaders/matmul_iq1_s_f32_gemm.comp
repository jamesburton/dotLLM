shared float sharedB[TILE_N * CHUNK];
shared float sharedW[TILE_M * CHUNK];

uint readByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

uint readU16(uint absByteOff) {
    return readByte(absByteOff) | (readByte(absByteOff + 1u) << 8u);
}

int sext8(uint b) {
    return int(b) - int((b & 0x80u) << 1u);
}

// Decode one of the 32 weight elements within an IQ1_S sub-block.
//   superBase = byte offset of the super-block start (within weight[])
//   ib        = sub-block index (0..7) within the super-block
//   elem      = element index (0..31) within the sub-block
//   d         = pre-loaded super-block scale
float decodeIq1SElement(uint superBase, uint ib, uint elem, float d) {
    uint qhVal = readU16(superBase + 2u + 32u + ib * 2u);
    float dl    = d * float(2 * int((qhVal >> 12u) & 7u) + 1);
    float delta = ((qhVal & 0x8000u) != 0u) ? -IQ1S_DELTA : IQ1S_DELTA;
    uint l = elem >> 3u;       // 0..3
    uint j = elem & 7u;        // 0..7
    uint qsByte = readByte(superBase + 2u + ib * 4u + l);
    uint idx    = qsByte | (((qhVal >> (3u * l)) & 7u) << 8u);
    uint gridLo = iq1s_grid_lo_hi[2u * idx];
    uint gridHi = iq1s_grid_lo_hi[2u * idx + 1u];
    uint gridWord = (j < 4u) ? gridLo : gridHi;
    int  g        = sext8((gridWord >> ((j & 3u) * 8u)) & 0xFFu);
    return dl * (float(g) + delta);
}

void main() {
    uint m = gl_WorkGroupID.x * TILE_M + gl_LocalInvocationID.x;
    uint t = gl_WorkGroupID.y * TILE_N + gl_LocalInvocationID.y;
    uint tid = gl_LocalInvocationID.y * TILE_M + gl_LocalInvocationID.x;

    uint mBase = gl_WorkGroupID.x * TILE_M;
    uint tBase = gl_WorkGroupID.y * TILE_N;

    uint rowByteStride = pc.blocksPerRow * IQ1_S_BLOCK_BYTES;
    uint totalChunks = pc.blocksPerRow * IQ1_S_NUM_SUB_BLOCKS;

    float acc = 0.0;

    for (uint chunk = 0u; chunk < totalChunks; chunk++) {
        uint sb = chunk / IQ1_S_NUM_SUB_BLOCKS;
        uint ib = chunk - sb * IQ1_S_NUM_SUB_BLOCKS;
        uint kBase = chunk * CHUNK;

        // ── 1. Stage sharedB[TILE_N, 32] (16x32 floats). 256 threads load 2 each. ──
        {
            uint flat0 = tid * 2u;
            uint flat1 = flat0 + 1u;

            uint row0 = flat0 >> 5u;
            uint col0 = flat0 - (row0 << 5u);
            uint row1 = flat1 >> 5u;
            uint col1 = flat1 - (row1 << 5u);

            uint tGlobal0 = tBase + row0;
            uint tGlobal1 = tBase + row1;

            float v0 = 0.0;
            float v1 = 0.0;
            if (tGlobal0 < pc.N) v0 = b[tGlobal0 * pc.K + kBase + col0];
            if (tGlobal1 < pc.N) v1 = b[tGlobal1 * pc.K + kBase + col1];
            sharedB[flat0] = v0;
            sharedB[flat1] = v1;
        }

        // ── 2. Dequantize sharedW[TILE_M, 32]. ──
        // 16 weight rows. 16 threads per row, each lane handles 2 columns
        // (lane and lane + 16).
        {
            uint mLocal  = tid >> 4u;             // 0..15 — row within tile
            uint lane    = tid - (mLocal << 4u);  // 0..15 — column-pair lane
            uint mGlobal = mBase + mLocal;

            bool rowValid = mGlobal < pc.M;
            float wLo = 0.0;
            float wHi = 0.0;
            if (rowValid) {
                uint superBase = mGlobal * rowByteStride + sb * IQ1_S_BLOCK_BYTES;
                float d = readHalf(superBase);
                wLo = decodeIq1SElement(superBase, ib, lane,        d);
                wHi = decodeIq1SElement(superBase, ib, lane + 16u,  d);
            }

            uint sBase = mLocal * CHUNK;
            sharedW[sBase + lane]         = wLo;
            sharedW[sBase + lane + 16u]   = wHi;
        }

        barrier();

        // ── 3. Partial dot product for this K-chunk. ──
        {
            uint bOff = gl_LocalInvocationID.y * CHUNK;
            uint wOff = gl_LocalInvocationID.x * CHUNK;
            float chunkSum = 0.0;
            for (uint j = 0u; j < CHUNK; j++) {
                chunkSum += sharedB[bOff + j] * sharedW[wOff + j];
            }
            acc += chunkSum;
        }

        barrier();
    }

    if (m < pc.M && t < pc.N) {
        c[t * pc.M + m] = acc;
    }
}
