// IQ1_S batched matrix multiplication (prefill-path GEMM).
//
//   C[N, M] = B[N, K] @ W_iq1s[M, K]^T      with W_iq1s dequantized on the fly.
//
// Companion to matmul_iq1_s_f32_gemv.comp. Same byte layout: each weight row
// holds (K / 256) IQ1_S super-blocks of 50 bytes:
//   bytes [0,1]    = fp16 d
//   bytes [2..33]  = qs[32]
//   bytes [34..49] = qh[8]   (uint16 LE per 32-element sub-block)
//
// Tiling:
//   Output tile  = 16 rows of C (TILE_N) x 16 cols of C (TILE_M) = 256 cells.
//   Workgroup    = (16, 16, 1) = 256 threads, one thread per output cell.
//   K-chunk      = 32 elements (one IQ1_S sub-block; 8 chunks per super-block).
//
// Per K-chunk we dequantise a 16x32 weight tile into shared memory once and
// reuse it across all 16 token rows of B.

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufB { float b[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufC { float c[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;             // multiple of 256
    uint N;
    uint blocksPerRow;  // = K / 256
    uint rowUints;
} pc;

const uint TILE_M = 16u;
const uint TILE_N = 16u;
const uint CHUNK  = 32u;             // K-chunk = one IQ1_S sub-block
