// IQ1_S matrix-vector multiplication (decode-path GEMV).
//
//   y[m] = sum_k  W_iq1s[m, k] * x[k]      with W_iq1s dequantized on the fly.
//
// Weight layout mirrors llama.cpp's block_iq1_s and DotLLM.Cpu.Kernels.Dequantize
// .DequantizeIQ1_S: each 256 contiguous elements of a row form one IQ1_S
// super-block of 50 bytes:
//   bytes [0,1]    = fp16 d
//   bytes [2..33]  = qs[32]   — low 8 bits of grid index per group of 8 elements
//   bytes [34..49] = qh[8]    — uint16 LE per 32-element sub-block:
//                                 bits  0..2  = grid-index high 3 bits for group 0
//                                 bits  3..5  = ...                    for group 1
//                                 bits  6..8  = ...                    for group 2
//                                 bits  9..11 = ...                    for group 3
//                                 bits 12..14 = 3-bit per-block scale
//                                 bit  15     = sign of delta (0 -> +0.125, 1 -> -)
//   Row stride = (K / 256) * 50 bytes.
//
// Reconstruction (8 sub-blocks of 32 elements, 4 groups of 8 each):
//   dl    = d * (2 * ((qh[ib] >> 12) & 7) + 1)
//   delta = (qh[ib] & 0x8000) ? -IQ1S_DELTA : +IQ1S_DELTA
//   idx   = qs[ib*4 + l] | (((qh[ib] >> 3*l) & 7) << 8)   // 11-bit
//   y[j]  = dl * (grid[j] + delta)
// where grid is the 2048-entry signed-int8 ggml iq1s_grid (each entry packs
// 8 ternary {-1, 0, +1} values into one uint64).
//
// x[] is FP32. Output y[] is FP32. N=1 decode path. Same dispatch shape as the
// IQ4_XS GEMV: one workgroup per output row, 128 threads, shared-memory tree
// reduce. Threads stride over the K/256 super-blocks per row.

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufX { float x[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufY { float y[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;             // multiple of 256
    uint blocksPerRow;  // = K / 256
    uint rowUints;      // per-row uint stride bound (rounded up)
} pc;

const uint IQ1_S_BLOCK_BYTES     = 50u;
const uint IQ1_S_GROUP_SIZE      = 256u;
const uint IQ1_S_NUM_SUB_BLOCKS  = 8u;
const uint IQ1_S_SUB_BLOCK_SIZE  = 32u;
const float IQ1S_DELTA = 0.125;

