uint readByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

uint readU16(uint absByteOff) {
    return readByte(absByteOff) | (readByte(absByteOff + 1u) << 8u);
}

int sext8(uint b) {
    return int(b) - int((b & 0x80u) << 1u);
}

shared float partials[128];

void main() {
    uint m = gl_WorkGroupID.x;
    if (m >= pc.M) return;

    uint tid = gl_LocalInvocationID.x;
    uint threads = gl_WorkGroupSize.x;

    uint rowByteStride = pc.blocksPerRow * IQ1_S_BLOCK_BYTES;
    uint rowByteBase = m * rowByteStride;

    float acc = 0.0;

    for (uint b = tid; b < pc.blocksPerRow; b += threads) {
        uint blockByteBase = rowByteBase + b * IQ1_S_BLOCK_BYTES;
        float d = readHalf(blockByteBase);
        uint qsBase = blockByteBase + 2u;
        uint qhBase = blockByteBase + 2u + 32u;
        uint xBase = b * IQ1_S_GROUP_SIZE;

        for (uint ib = 0u; ib < IQ1_S_NUM_SUB_BLOCKS; ib++) {
            uint qhVal = readU16(qhBase + ib * 2u);
            float dl    = d * float(2 * int((qhVal >> 12u) & 7u) + 1);
            float delta = ((qhVal & 0x8000u) != 0u) ? -IQ1S_DELTA : IQ1S_DELTA;

            uint subQsBase = qsBase + ib * 4u;
            uint subXBase  = xBase + ib * IQ1_S_SUB_BLOCK_SIZE;

            float subSum = 0.0;
            for (uint l = 0u; l < 4u; l++) {
                uint qsByte = readByte(subQsBase + l);
                uint idx    = qsByte | (((qhVal >> (3u * l)) & 7u) << 8u);
                uint gridLo = iq1s_grid_lo_hi[2u * idx];
                uint gridHi = iq1s_grid_lo_hi[2u * idx + 1u];

                uint groupX = subXBase + l * 8u;
                // Unrolled 8-element accumulate. Bytes 0..3 from gridLo, 4..7 from gridHi.
                subSum += x[groupX + 0u] * (float(sext8( gridLo        & 0xFFu)) + delta);
                subSum += x[groupX + 1u] * (float(sext8((gridLo >>  8u) & 0xFFu)) + delta);
                subSum += x[groupX + 2u] * (float(sext8((gridLo >> 16u) & 0xFFu)) + delta);
                subSum += x[groupX + 3u] * (float(sext8((gridLo >> 24u) & 0xFFu)) + delta);
                subSum += x[groupX + 4u] * (float(sext8( gridHi        & 0xFFu)) + delta);
                subSum += x[groupX + 5u] * (float(sext8((gridHi >>  8u) & 0xFFu)) + delta);
                subSum += x[groupX + 6u] * (float(sext8((gridHi >> 16u) & 0xFFu)) + delta);
                subSum += x[groupX + 7u] * (float(sext8((gridHi >> 24u) & 0xFFu)) + delta);
            }
            acc += dl * subSum;
        }
    }

    partials[tid] = acc;
    barrier();
    for (uint stride = threads >> 1u; stride > 0u; stride >>= 1u) {
        if (tid < stride) partials[tid] = partials[tid] + partials[tid + stride];
        barrier();
    }

    if (tid == 0u) y[m] = partials[0];
}
