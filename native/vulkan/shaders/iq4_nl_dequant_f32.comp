#version 450
// IQ4_NL dequantization to FP32.
//
// Reads a tightly-packed IQ4_NL blob (one 18-byte block per 32 elements) and
// produces a contiguous FP32 buffer of the dequantized values. Layout matches
// llama.cpp's block_iq4_nl and DotLLM.Cpu.Kernels.Dequantize.DequantizeIQ4_NL.
//
// Dispatch:
//   One workgroup per IQ4_NL block. local_size_x = 32 — one thread per element.

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  src[]; };
layout(set = 0, binding = 1, std430) writeonly buffer BufY { float dst[]; };

layout(push_constant) uniform PushConstants {
    uint totalBlocks;   // number of IQ4_NL blocks
    uint srcUints;      // total uints in src[] (bounds for safe straddle reads)
} pc;

const uint IQ4_NL_BLOCK_BYTES = 18u;
const uint IQ4_NL_GROUP_SIZE  = 32u;

const float KVALUES_IQ4NL[16] = float[16](
    -127.0, -104.0, -83.0, -65.0, -49.0, -35.0, -22.0, -10.0,
       1.0,   13.0,  25.0,  38.0,  53.0,  69.0,  89.0, 113.0
);

uint readByte(uint absByteOff) {
    uint u = src[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = src[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = src[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

void main() {
    uint block = gl_WorkGroupID.x;
    if (block >= pc.totalBlocks) return;

    uint t = gl_LocalInvocationID.x;       // 0..31 — element within block
    uint blockBase = block * IQ4_NL_BLOCK_BYTES;
    float d = readHalf(blockBase);

    uint j = t & 15u;                       // qs byte index
    uint qsByte = readByte(blockBase + 2u + j);
    uint nibble = (t < 16u) ? (qsByte & 0xFu) : (qsByte >> 4u);

    dst[block * IQ4_NL_GROUP_SIZE + t] = d * KVALUES_IQ4NL[nibble];
}
