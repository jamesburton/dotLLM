#version 450
// Q3_K batched matrix multiplication (prefill-path GEMM).
//
//   C[N, M] = B[N, K] @ W_q3k[M, K]^T      with W_q3k dequantized on the fly.
//
// Companion to matmul_q3_k_f32_gemv.comp (decode-path GEMV) and structural
// sibling of matmul_q2_k_f32_gemm.comp (same 16-element K-chunk geometry —
// Q2_K and Q3_K both organise their super-blocks as 16 sub-blocks of 16
// elements, while Q4/5/6_K use 8 sub-blocks of 32). See the GEMV kernel
// for the byte-extraction commentary.
//
// Block layout (matches DotLLM.Cpu.Kernels.DequantizeKQuants.DequantizeQ3_KScalar):
//   Each row holds (K / 256) Q3_K super-blocks of 110 bytes each:
//       bytes [  0.. 31] = hmask[32]   (1 high bit per element)
//       bytes [ 32.. 95] = qs[64]      (2 low bits per element, 4 per byte)
//       bytes [ 96..107] = scales[12]  (16 × 6-bit unsigned, biased by -32)
//       bytes [108,109]  = fp16 d
//   Row stride = (K / 256) * 110 bytes — NOT 4-aligned (110 % 4 == 2),
//   so readHalf must straddle.
//
// Tiling:
//   Output tile  = 16 rows of C (TILE_N) × 16 cols of C (TILE_M) = 256 cells.
//   Workgroup    = (16, 16, 1) = 256 threads, one thread per output cell.
//   K-chunk      = 16 elements (one Q3_K sub-block).

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW { uint  weight[]; };
layout(set = 0, binding = 1, std430) readonly  buffer BufB { float b[]; };
layout(set = 0, binding = 2, std430) writeonly buffer BufC { float c[]; };

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint N;
    uint blocksPerRow;
    uint rowUints;
} pc;

const uint TILE_M = 16u;
const uint TILE_N = 16u;
const uint SUBBLOCK = 16u;
const uint Q3K_BLOCK_BYTES = 110u;
const uint Q3K_GROUP_SIZE  = 256u;
const uint NUM_SUBBLOCKS   = 16u;

shared float sharedB[TILE_N * SUBBLOCK];
shared float sharedW[TILE_M * SUBBLOCK];

uint readByte(uint absByteOff) {
    uint u = weight[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = weight[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = weight[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

int unpackQ3Scale(uint scalesBase, uint sub) {
    uint lowNibble;
    if (sub < 8u) {
        lowNibble = readByte(scalesBase + sub) & 0xFu;
    } else {
        lowNibble = (readByte(scalesBase + (sub - 8u)) >> 4u) & 0xFu;
    }
    uint hiByte  = 8u + (sub >> 2u);
    uint hiShift = (sub & 3u) << 1u;
    uint hiBits  = (readByte(scalesBase + hiByte) >> hiShift) & 0x3u;
    uint scale6  = lowNibble | (hiBits << 4u);
    return int(scale6) - 32;
}

void main() {
    uint m = gl_WorkGroupID.x * TILE_M + gl_LocalInvocationID.x;
    uint t = gl_WorkGroupID.y * TILE_N + gl_LocalInvocationID.y;

    uint tid = gl_LocalInvocationID.y * TILE_M + gl_LocalInvocationID.x;

    uint mBase = gl_WorkGroupID.x * TILE_M;
    uint tBase = gl_WorkGroupID.y * TILE_N;

    uint rowByteStride = pc.blocksPerRow * Q3K_BLOCK_BYTES;

    float acc = 0.0;

    uint totalChunks = pc.blocksPerRow * NUM_SUBBLOCKS;
    for (uint chunk = 0u; chunk < totalChunks; chunk++) {
        uint kBlock = chunk / NUM_SUBBLOCKS;
        uint subIdx = chunk - kBlock * NUM_SUBBLOCKS;
        uint kBase  = kBlock * Q3K_GROUP_SIZE + subIdx * SUBBLOCK;

        // ── 1. Stage sharedB[TILE_N, 16]. 256 threads, one float each. ──
        {
            uint row = tid >> 4u;
            uint col = tid & 15u;
            uint tGlobal = tBase + row;
            float v = 0.0;
            if (tGlobal < pc.N) v = b[tGlobal * pc.K + kBase + col];
            sharedB[row * SUBBLOCK + col] = v;
        }

        // ── 2. Dequantize sharedW[TILE_M, 16]. ──
        {
            uint mLocal  = tid >> 4u;
            uint col     = tid & 15u;
            uint mGlobal = mBase + mLocal;

            float w = 0.0;
            if (mGlobal < pc.M) {
                uint blockByteBase = mGlobal * rowByteStride + kBlock * Q3K_BLOCK_BYTES;
                uint hmaskBase  = blockByteBase;
                uint qsBase     = blockByteBase + 32u;
                uint scalesBase = blockByteBase + 96u;
                float d         = readHalf(blockByteBase + 108u);

                int signedSc = unpackQ3Scale(scalesBase, subIdx);
                float scF = d * float(signedSc);

                uint elem   = subIdx * SUBBLOCK + col;
                uint qByte  = readByte(qsBase + (elem >> 2u));
                uint bitOff = (elem & 3u) << 1u;
                uint qBits  = (qByte >> bitOff) & 0x3u;
                uint hByte  = readByte(hmaskBase + (elem >> 3u));
                uint hBit   = (hByte >> (elem & 7u)) & 0x1u;
                int signed3 = int((hBit << 2u) | qBits) - 4;

                w = scF * float(signed3);
            }
            sharedW[mLocal * SUBBLOCK + col] = w;
        }

        barrier();

        // ── 3. Partial dot product. ──
        {
            uint bOff = gl_LocalInvocationID.y * SUBBLOCK;
            uint wOff = gl_LocalInvocationID.x * SUBBLOCK;
            float chunkSum = 0.0;
            for (uint j = 0u; j < SUBBLOCK; j++) {
                chunkSum += sharedB[bOff + j] * sharedW[wOff + j];
            }
            acc += chunkSum;
        }

        barrier();
    }

    if (m < pc.M && t < pc.N) {
        c[t * pc.M + m] = acc;
    }
}
