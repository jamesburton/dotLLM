#version 450
// IQ2_XXS dequantization to FP32.
//
// Reads a tightly-packed IQ2_XXS blob (one 66-byte super-block per 256
// elements) and produces a contiguous FP32 buffer. Layout matches llama.cpp's
// block_iq2_xxs and DotLLM.Cpu.Kernels.Dequantize.DequantizeIQ2_XXS:
//     bytes [0,1]    = fp16 d
//     bytes [2..65]  = qs[32] uint16, organised as 8 sub-blocks of 8 bytes:
//                      a0 (uint32) = 4 byte indices into the 256-entry grid;
//                      a1 (uint32) = 4*7-bit sign indices (low 28) + 4-bit
//                                    shared sub-scale (top nibble).
//   Per-element value:
//     db  = d * (0.5 + (a1 >> 28)) * 0.25
//     val = db * grid[gridIdx*8 + j] * (signs & (1<<j) ? -1 : +1)
//   where signs = ksigns[signsIdx].
//
// Dispatch:
//   One workgroup per IQ2_XXS super-block. local_size_x = 256 — one thread
//   per element (8 sub-blocks * 4 pairs * 8 elements).

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly  buffer BufW       { uint  src[]; };
layout(set = 0, binding = 1, std430) writeonly buffer BufY       { float dst[]; };
layout(set = 0, binding = 2, std430) readonly  buffer BufGrid    { uint  iq2xxsGrid[]; };  // 2048 bytes = 512 uints
layout(set = 0, binding = 3, std430) readonly  buffer BufKsigns  { uint  ksigns[]; };       // 128 bytes = 32 uints

layout(push_constant) uniform PushConstants {
    uint totalSuperblocks;
    uint srcUints;
} pc;

const uint IQ2_XXS_BLOCK_BYTES = 66u;
const uint IQ2_XXS_GROUP_SIZE  = 256u;

uint readByte(uint absByteOff) {
    uint u = src[absByteOff >> 2u];
    uint shift = (absByteOff & 3u) * 8u;
    return (u >> shift) & 0xFFu;
}

float readHalf(uint absByteOff) {
    uint alignedIdx = absByteOff >> 2u;
    uint byteInWord = absByteOff & 3u;
    uint u = src[alignedIdx];
    uint half16;
    if (byteInWord <= 2u) {
        half16 = (u >> (byteInWord * 8u)) & 0xFFFFu;
    } else {
        uint uNext = src[alignedIdx + 1u];
        half16 = ((u >> 24) & 0xFFu) | ((uNext & 0xFFu) << 8);
    }
    return unpackHalf2x16(half16).x;
}

uint gridByte(uint absIdx) {
    uint u = iq2xxsGrid[absIdx >> 2u];
    return (u >> ((absIdx & 3u) * 8u)) & 0xFFu;
}

uint ksignByte(uint absIdx) {
    uint u = ksigns[absIdx >> 2u];
    return (u >> ((absIdx & 3u) * 8u)) & 0xFFu;
}

void main() {
    uint sb = gl_WorkGroupID.x;
    if (sb >= pc.totalSuperblocks) return;

    uint t = gl_LocalInvocationID.x;       // 0..255
    uint blockBase = sb * IQ2_XXS_BLOCK_BYTES;
    float d = readHalf(blockBase);
    uint qsBase = blockBase + 2u;

    uint ib32 = t >> 5u;       // 0..7  (sub-block)
    uint rem  = t & 31u;       // 0..31
    uint l    = rem >> 3u;     // 0..3  (pair)
    uint j    = rem & 7u;      // 0..7  (element in pair)

    uint p = qsBase + 8u * ib32;
    uint a0 = readByte(p)
            | (readByte(p + 1u) << 8)
            | (readByte(p + 2u) << 16)
            | (readByte(p + 3u) << 24);
    uint a1 = readByte(p + 4u)
            | (readByte(p + 5u) << 8)
            | (readByte(p + 6u) << 16)
            | (readByte(p + 7u) << 24);

    uint gridIdx  = (a0 >> (8u * l)) & 0xFFu;
    uint signsIdx = (a1 >> (7u * l)) & 0x7Fu;
    float db = d * (0.5 + float(a1 >> 28)) * 0.25;

    uint signs = ksignByte(signsIdx);
    float g    = float(gridByte(gridIdx * 8u + j));
    float sign = ((signs & (1u << j)) != 0u) ? -1.0 : 1.0;

    dst[sb * IQ2_XXS_GROUP_SIZE + t] = db * g * sign;
}
